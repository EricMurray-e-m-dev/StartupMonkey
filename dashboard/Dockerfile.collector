FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY dashboard/package*.json ./

# Install dependencies
RUN npm ci --only=production

# Copy collector script
COPY dashboard/lib/collector.js ./lib/

# Copy stores directory
COPY dashboard/stores/ ./stores/

# Copy proto files
COPY proto/ /proto/

EXPOSE 3001

CMD ["node", "lib/collector.js"]